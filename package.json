{
  "name": "@triforce-heroes/triforce-core",
  "version": "1.0.0",
  "description": "Triforce Core libraries.",
  "license": "Apache License 2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./Array": "./dist/Array.js",
    "./Buffer": "./dist/Buffer.js",
    "./BufferBuilder": "./dist/BufferBuilder.js",
    "./BufferConsumer": "./dist/BufferConsumer.js",
    "./Cache": "./dist/Cache.js",
    "./Console": "./dist/Console.js",
    "./ConsoleHexadecimal": "./dist/ConsoleHexadecimal.js",
    "./Debugger": "./dist/Debugger.js",
    "./Encoding": "./dist/Encoding.js",
    "./Hash": "./dist/Hash.js",
    "./Number": "./dist/Number.js",
    "./Path": "./dist/Path.js",
    "./types/ByteOrder": "./dist/types/ByteOrder.js",
    "./types/PrintHexadecimalPreset": "./dist/types/PrintHexadecimalPreset.js"
  },
  "scripts": {
    "build": "npm run eslint:fix && npm build:faster",
    "build:faster": "npm run oxfmt:fix && rimraf ./dist && tspc -p ./tsconfig.build.json && swc ./dist -d .",
    "typecheck": "tsc --noEmit",
    "oxfmt": "oxfmt --check ./src ./tests",
    "oxfmt:fix": "oxfmt --write ./src ./tests",
    "eslint": "eslint ./src ./tests",
    "eslint:fix": "eslint --fix ./src ./tests",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "json-diff": "^1.0.6"
  },
  "devDependencies": {
    "@rheactor/eslint-config-rheactor": "github:rheactor/eslint-config-rheactor",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.40",
    "@types/json-diff": "^1.0.3",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "commander": "^14.0.3",
    "eslint": "^10.4.0",
    "oxfmt": "^0.51.0",
    "rimraf": "^6.1.3",
    "strip-ansi": "^7.2.0",
    "ts-patch": "^4.0.1",
    "typescript": "^6.0.3",
    "typescript-transform-paths": "^4.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  }
}
